# SPA fallback: serve index.html for any route that isn't a real file/folder,
# so clean URLs like /services, /projects, /projects/<slug> work on refresh.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
